# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Tier 1: Cloud LLM (Gemini) ──────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Tier 2: Local SLM (Ollama) ──────────────────────────────────────────────
# Model tag to use for the retained SLM 3b (anomaly params)
# OLLAMA_MODEL=qwen3:4b

# ── HITL auto-approve (set to 1 for non-interactive / CI use) ────────────────
# HITL_AUTO=0
